# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# Supabase Configuration
VITE_SUPABASE_URL="your-supabase-url"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key" # REQUIRED for server-side admin operations

# Razorpay Configuration (Server-side)
# IMPORTANT: Ensure there are no extra spaces or quotes around the values
RAZORPAY_KEY_ID="rzp_live_..."
RAZORPAY_KEY_SECRET="your_secret"
RAZORPAY_SECRET="your_secret" # Alias for RAZORPAY_KEY_SECRET

# Razorpay Configuration (Client-side)
VITE_RAZORPAY_KEY_ID="rzp_live_..."
VITE_RAZORPAY_KEY="rzp_live_..." # Alias for VITE_RAZORPAY_KEY_ID
